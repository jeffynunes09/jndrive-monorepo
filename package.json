{
  "name": "jndrive-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:admin": "pnpm --filter admin dev",
    "build:all": "pnpm -r build",
    "lint:all": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@aws-sdk/client-s3": "3.972.0",
      "@aws-sdk/s3-request-presigner": "3.972.0"
    }
  }
}